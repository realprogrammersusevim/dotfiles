{
  "Class Notes": {
    "prefix": "notes",
    "body": [
      "#import \"@local/notable:0.9.0\": *",
      "#show: notable.with(",
      "  title: \"${1:title}\",",
      ")"
    ],
    "description": "Template for class notes using my personal notable notes package"
  },
  "Graph Weight": {
    "prefix": "label",
    "body": [
      "[label=\\\"${1:label}\\\", weight=\\\"${2:weight}\\\"]"
    ],
    "description": "Add label and weight to graphviz graph"
  },
  "Figure": {
    "prefix": "fig",
    "body": [
       "#figure(",
       " ${1:content} ,",
       "caption : [${2:caption}]",
       ")<${3:reference}>"
    ],
    "description": "Figure"
 },
 "Table": {
  "prefix": "table",
  "body": [
     "#table(",
     "  columns: ${1:columns},",
     "  table.header([${2:header}]),",
     "  [${3:data}]",
     ")"
  ],
  "description": "Table"
 }
}
